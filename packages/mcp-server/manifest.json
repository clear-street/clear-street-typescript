{
  "dxt_version": "0.2",
  "name": "@clear-street-internal/sdk-mcp",
  "version": "0.47.0",
  "description": "The official MCP Server for the Clear Street API",
  "author": {
    "name": "Clear Street",
    "email": "support@clearstreet.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clear-street/clear-street-typescript.git"
  },
  "homepage": "https://github.com/clear-street/clear-street-typescript/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "CLEAR_STREET_API_KEY": "${user_config.CLEAR_STREET_API_KEY}"
      }
    }
  },
  "user_config": {
    "CLEAR_STREET_API_KEY": {
      "title": "api_key",
      "description": "A JWT issued by the authentication service.",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
